{
  "name": "household-refill-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node --import tsx prisma/seed.ts",
    "setup": "pnpm db:generate && pnpm db:deploy && pnpm db:seed",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "lucide-react": "0.468.0",
    "next": "14.2.35",
    "next-auth": "4.24.14",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/node": "22.10.7",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "dotenv": "16.6.1",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.49",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "4.22.4",
    "typescript": "5.7.3"
  }
}
